<!DOCTYPE html>
<html lang="mn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dark Analytics Dashboard | Pro Edition</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --body-bg: #0f172a;      /* Гүн хөх */
            --card-bg: #1e293b;      /* Цайвар хөх */
            --sidebar-bg: #111827;   /* Харанхуй саарал/хөх */
            --accent: #38bdf8;       /* Тод цэнхэр */
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Roboto, sans-serif;
            background-color: var(--body-bg);
            color: var(--text-main);
            margin: 0;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            height: 100vh;
            position: fixed;
            z-index: 1000;
            transition: all 0.3s;
        }

        .sidebar .logo {
            padding: 30px 25px;
            font-size: 24px;
            font-weight: 800;
            color: var(--accent);
            letter-spacing: 1px;
        }

        .sidebar h6 {
            color: var(--text-muted);
            padding: 10px 25px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .sidebar .nav-link {
            color: var(--text-muted);
            padding: 12px 25px;
            margin: 4px 15px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            transition: 0.2s;
        }

        .sidebar .nav-link:hover, .sidebar .nav-link.active {
            color: #fff;
            background: rgba(56, 189, 248, 0.15);
        }

        .sidebar .nav-link.active {
            background-color: var(--accent);
            color: var(--body-bg);
            font-weight: 600;
        }

        .sidebar .nav-link i { margin-right: 12px; font-size: 18px; }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 260px;
            padding: 40px;
            width: calc(100% - 260px);
        }

        /* Top Bar */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--card-bg);
            padding: 6px 15px;
            border-radius: 50px;
            border: 1px solid var(--border);
        }

        /* Card Styling */
        .card-custom {
            background-color: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 25px;
            height: 100%;
            transition: 0.3s;
        }

        .card-custom:hover {
            border-color: var(--accent);
            transform: translateY(-5px);
        }

        .kpi-title { color: var(--text-muted); font-size: 14px; margin-bottom: 8px; }
        .kpi-value { font-size: 28px; font-weight: 700; }

        .badge-up { color: #4ade80; background: rgba(74, 222, 128, 0.1); padding: 4px 8px; border-radius: 6px; font-size: 12px; }
        .badge-down { color: #f87171; background: rgba(248, 113, 113, 0.1); padding: 4px 8px; border-radius: 6px; font-size: 12px; }

        /* Progress Bars */
        .prog-label { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 8px; }
        .progress { height: 8px; background-color: #334155; border-radius: 10px; margin-bottom: 20px; }
        .progress-bar { background-color: var(--accent); }

        /* List Items */
        .list-group-item {
            background: transparent;
            border: none;
            border-bottom: 1px solid var(--border);
            padding: 15px 0;
            color: var(--text-main);
        }
        .list-group-item:last-child { border: none; }

        /* Responsive */
        @media (max-width: 992px) {
            .sidebar { width: 80px; }
            .sidebar .logo span, .sidebar h6, .sidebar span { display: none; }
            .main-content { margin-left: 80px; width: calc(100% - 80px); padding: 20px; }
            .sidebar .nav-link { justify-content: center; margin: 5px; }
            .sidebar .nav-link i { margin-right: 0; }
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="logo"><i class="fa fa-bolt"></i><span> ACURA</span></div>
        
        <h6>Цэсүүд</h6>
        <nav class="nav flex-column">
            <a class="nav-link active" href="#"><i class="fa fa-chart-line"></i> <span>Анализ</span></a>
            <a class="nav-link" href="#"><i class="fa fa-shopping-bag"></i> <span>Борлуулалт</span></a>
            <a class="nav-link" href="#"><i class="fa fa-users"></i> <span>Хэрэглэгчид</span></a>
        </nav>

        <h6 class="mt-4">Систем</h6>
        <nav class="nav flex-column">
            <a class="nav-link" href="#"><i class="fa fa-calendar"></i> <span>Хуанли</span></a>
            <a class="nav-link" href="#"><i class="fa fa-cog"></i> <span>Тохиргоо</span></a>
        </nav>
    </aside>

    <main class="main-content">
        
        <header class="top-bar">
            <div>
                <h2 class="fw-bold mb-0">Анализ тойм</h2>
                <p class="text-muted">Системийн өнөөдрийн байдал</p>
            </div>
            <div class="user-profile">
                <div class="text-end">
                    <div class="small fw-bold">Кейт Дадли</div>
                    <div class="small text-muted" style="font-size: 10px;">Админ</div>
                </div>
                <img src="https://i.pravatar.cc/150?u=kate" width="35" height="35" class="rounded-circle" alt="user">
            </div>
        </header>

        <div class="row g-4 mb-4">
            <div class="col-xl-3 col-md-6">
                <div class="card-custom">
                    <div class="kpi-title">Нийт Зочид</div>
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="kpi-value">24.8k</div>
                        <span class="badge-up">+14% <i class="fa fa-caret-up"></i></span>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card-custom">
                    <div class="kpi-title">Сессүүд</div>
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="kpi-value">5,120</div>
                        <span class="badge-down">-2.4% <i class="fa fa-caret-down"></i></span>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card-custom">
                    <div class="kpi-title">Bounce Rate</div>
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="kpi-value">28.5%</div>
                        <span class="badge-up">-1.2% <i class="fa fa-caret-up"></i></span>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card-custom">
                    <div class="kpi-title">Орлого</div>
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="kpi-value">$12.4k</div>
                        <span class="badge-up">+8% <i class="fa fa-caret-up"></i></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-12">
                <div class="card-custom">
                    <h5 class="fw-bold mb-4">Хэрэглэгчийн урсгал (Сүүлийн 12 хоног)</h5>
                    <div style="height: 350px;">
                        <canvas id="mainChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card-custom">
                    <h5 class="fw-bold mb-4">Хөтөчийн ашиглалт</h5>
                    <div class="prog-item">
                        <div class="prog-label"><span>Chrome</span> <span>75%</span></div>
                        <div class="progress"><div class="progress-bar" style="width: 75%"></div></div>
                    </div>
                    <div class="prog-item">
                        <div class="prog-label"><span>Safari</span> <span>18%</span></div>
                        <div class="progress"><div class="progress-bar" style="width: 18%; background-color: #a78bfa;"></div></div>
                    </div>
                    <div class="prog-item">
                        <div class="prog-label"><span>Firefox</span> <span>7%</span></div>
                        <div class="progress"><div class="progress-bar" style="width: 7%; background-color: #fb923c;"></div></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card-custom">
                    <h5 class="fw-bold mb-4">Төхөөрөмж</h5>
                    <div style="height: 250px;">
                        <canvas id="deviceChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card-custom">
                    <h5 class="fw-bold mb-3">Шилдэг эх сурвалж</h5>
                    <div class="list-group">
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div><i class="fab fa-google text-primary me-2"></i> Google Search</div>
                            <span class="badge bg-dark">45%</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div><i class="fab fa-facebook text-info me-2"></i> Facebook Social</div>
                            <span class="badge bg-dark">32%</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div><i class="fa fa-envelope text-warning me-2"></i> Email Campaign</div>
                            <span class="badge bg-dark">15%</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div><i class="fa fa-link text-muted me-2"></i> Бусад</div>
                            <span class="badge bg-dark">8%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Глобал тохиргоо - Dark Mode Chart
            Chart.defaults.color = '#94a3b8';
            Chart.defaults.borderColor = '#334155';

            // 1. Main Area Chart
            const mainCtx = document.getElementById('mainChart').getContext('2d');
            const mainGradient = mainCtx.createLinearGradient(0, 0, 0, 400);
            mainGradient.addColorStop(0, 'rgba(56, 189, 248, 0.4)');
            mainGradient.addColorStop(1, 'rgba(56, 189, 248, 0)');

            new Chart(mainCtx, {
                type: 'line',
                data: {
                    labels: ['01 Jan', '02 Jan', '03 Jan', '04 Jan', '05 Jan', '06 Jan', '07 Jan', '08 Jan', '09 Jan', '10 Jan', '11 Jan', '12 Jan'],
                    datasets: [{
                        label: 'Зочид',
                        data: [1200, 1900, 1700, 2500, 2100, 3100, 3800, 3500, 4200, 4800, 4500, 5100],
                        borderColor: '#38bdf8',
                        backgroundColor: mainGradient,
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointBackgroundColor: '#38bdf8',
                        pointHoverRadius: 7
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { grid: { borderDash: [5, 5] }, beginAtZero: true },
                        x: { grid: { display: false } }
                    }
                }
            });

            // 2. Device Doughnut Chart
            const deviceCtx = document.getElementById('deviceChart').getContext('2d');
            new Chart(deviceCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Desktop', 'Mobile', 'Tablet'],
                    datasets: [{
                        data: [55, 35, 10],
                        backgroundColor: ['#38bdf8', '#fb7185', '#34d399'],
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%',
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 20, boxWidth: 12 } }
                    }
                }
            });
        });
    </script>
</body>
</html>
